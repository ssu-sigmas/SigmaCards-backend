# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://sigmacards:sigmacards_password_123@localhost:5432/sigmacards_db

# ==========================================
# SECURITY
# ==========================================
SECRET_KEY=your-super-secret-key-change-this-in-production-12345
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# ENVIRONMENT
# ==========================================
ENV=development

# ==========================================
# ML MICROSERVICE (только URL, никаких ключей)
# ==========================================
ML_SERVICE_URL=http://localhost:8001
ML_SERVICE_TIMEOUT=60

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO
