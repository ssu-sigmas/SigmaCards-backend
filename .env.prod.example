# =============================
# Domains and TLS
# =============================
PUBLIC_DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com
TRAEFIK_LOG_LEVEL=INFO

# =============================
# App Image (optional)
# =============================
APP_IMAGE=ghcr.io/ssu-sigmas/sigmacards-backend
APP_IMAGE_TAG=latest

# =============================
# Backend
# =============================
ENV=production
APP_PORT=8010
DATABASE_URL=postgresql://sigmacards:change-db-password@db:5432/sigmacards_db
REDIS_PASSWORD=change-redis-password
REDIS_URL=redis://:change-redis-password@redis:6379/0
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=INFO

# =============================
# Kafka
# =============================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ML_REQUEST_TOPIC=ml.cards.generate.request
KAFKA_ML_RESPONSE_TOPIC=ml.cards.generate.response
KAFKA_ML_CONSUMER_GROUP=sigmacards-ml-client
KAFKA_OCR_REQUEST_TOPIC=ml.cards.extract.request
KAFKA_OCR_RESPONSE_TOPIC=ml.cards.extract.response

# =============================
# S3-compatible storage
# =============================
STORAGE_PROVIDER=rustfs
S3_ENDPOINT=example.com:9000
S3_PUBLIC_ENDPOINT=rustfs.example.com
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-strong-secret
S3_BUCKET=card-images
S3_BUCKET_TEXT=card-text-chunks
S3_SECURE=true
S3_TEXT_TTL_DAYS=365