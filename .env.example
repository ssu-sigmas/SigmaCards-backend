# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://sigmacards:password@db:5432/sigmacards_db
REDIS_PASSWORD=change-this-password
REDIS_URL=redis://:change-this-password@redis:6379/0

# ==========================================
# SECURITY
# ==========================================
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# ENVIRONMENT
# ==========================================
ENV=development

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# S3-COMPATIBLE STORAGE
# ==========================================
STORAGE_PROVIDER=rustfs
S3_ENDPOINT=rustfs:9000
S3_PUBLIC_ENDPOINT=localhost:9000
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-strong-secret
S3_BUCKET=card-images
S3_SECURE=false